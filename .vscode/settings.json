{
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": false
  },
  "editor.suggestOnTriggerCharacters": true,
  "explorer.autoReveal": false,
  "files.exclude": {
    "**/.git": true,
    "**/.gitignore": true,
    "**/.gitattributes": true,
    "**/.godot": true,
    "**/.import": true,
    "**/*.import": true,
    "**/*.uid": true,
    "**/.vscode": true,
    "**/.vs": true,
    "**/android": true,
    "**/ios": true,
    "**/.mono": true,
    "**/bin": true,
    "**/obj": true,
    "**/*.blend1": true,
    "**/*.blend2": true,
    "**/node_modules": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  },
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "C_Cpp.intelliSenseEngine": "disabled",
  "C_Cpp.errorSquiggles": "disabled",
  "clangd.onConfigChanged": "restart",
  "clangd.fallbackFlags": [
    "-xc++",
    "-std=c++17",
    "-DGDEXTENSION",
    "-DTYPED_METHOD_BIND",
    "-DWINDOWS_ENABLED",
    "-DDEBUG_ENABLED",
    "-DNDEBUG",
    "-DNOMINMAX",
    "-I${workspaceFolder}/godot-cpp/gdextension",
    "-I${workspaceFolder}/godot-cpp/include",
    "-I${workspaceFolder}/godot-cpp/gen/include",
    "-I${workspaceFolder}/godot-cpp/src",
    "-I${workspaceFolder}/src",
    "-isystem",
    "C:/Program Files/Microsoft Visual Studio/18/Community/VC/Tools/MSVC/14.51.36231/include",
    "-isystem",
    "C:/Program Files (x86)/Windows Kits/10/Include/10.0.26100.0/ucrt",
    "-isystem",
    "C:/Program Files (x86)/Windows Kits/10/Include/10.0.26100.0/shared",
    "-isystem",
    "C:/Program Files (x86)/Windows Kits/10/Include/10.0.26100.0/um",
    "-isystem",
    "C:/Program Files (x86)/Windows Kits/10/Include/10.0.26100.0/winrt"
  ],
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}",
    "--query-driver=C:/Program Files/LLVM/bin/clang-cl.exe,C:/Program Files/LLVM/bin/clang++.exe,C:/Program Files/LLVM/bin/clang.exe,C:/Program Files/Microsoft Visual Studio/18/Community/VC/Tools/MSVC/*/bin/Hostx64/x64/cl.exe",
    "--all-scopes-completion",
    "--completion-style=detailed"
  ]
}
